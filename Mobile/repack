def repack(path):
      
    if(args.output):
          
      # Re-build the apk
      subprocess.run(['apktool', 'b',path, '-o', args.output], check=True)
      raw_name = Path(args.output).stem

      counter = 1
      while True:
        dir_name = f"{raw_name}{counter}"
        if not os.path.exists(dir_name):
          break
        counter +=1
      os.makedirs(dir_name,exist_ok=True)

      
      # Align the apk
      aligned_apk_path1 = Path(dir_name)
      aligned_apk_path2 = os.path.join(aligned_apk_path1, f"{dir_name}aligned.apk")
      subprocess.run(['zipalign', '-v', '4', args.output, aligned_apk_path2], check=True)

      # Re-sign the modified apk
      keystore = find_key_store()

      # prompt the user for the keystore password 
      keystore_pass = f"pass:{input('Please enter keystore password: ')}"
      key_pass = f"pass:{input('Please enter your key password: ')}"

      subprocess.run(['apksigner', 'sign','--ks', keystore, '--ks-pass', keystore_pass, '--key-pass', key_pass, aligned_apk_path2], check=True)

    
    # # if no output directory is provided
    # TODO: use the current directory

repack(args.apk_path)