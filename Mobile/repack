  search_path = os.path.expanduser('~')

  # If multiple key stores are returned, which to use? TO-DO
  keystore = subprocess.run(['find', search_path, '-name','*keystore1.jks'], capture_output=True, text=True)
  
  if(not keystore):
        
    # TO-DO : need to be tested
    print("No keystore found")
